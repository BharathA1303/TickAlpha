# pyenv
#   For a library or package, you might want to ignore these files since the values may not match the developer's system.
# .python-version

# pipenv
#   According to pypa/pipenv#1013, pipenv should ignore the Lockfile.
#   Anyway, for an application, you should keep Pipfile.lock in the git repo.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock should be kept in the git repo.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock should be kept in the git repo.
#pdm.lock

